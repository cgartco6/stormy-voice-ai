<!DOCTYPE html>
<html lang="en-ZA">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <title>Stormy | Empire OS</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700;900&display=swap" rel="stylesheet">
    <style>
        :root { --accent: #00f2ff; --angry: #ff0055; --glass: rgba(0, 0, 0, 0.9); }
        * { box-sizing: border-box; -webkit-tap-highlight-color: transparent; margin: 0; padding: 0; }
        body, html { width: 100vw; height: 100vh; background: #000; color: white; font-family: 'Inter', sans-serif; overflow: hidden; position: fixed; }
        #bg-container { position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: -1; }
        .bg-img { position: absolute; width: 100%; height: 100%; object-fit: cover; transition: opacity 0.6s ease; filter: brightness(0.4); }
        #mood-bar { position: fixed; top: env(safe-area-inset-top, 20px); left: 50%; transform: translateX(-50%); padding: 12px 30px; border-radius: 50px; background: var(--glass); backdrop-filter: blur(15px); border: 1px solid rgba(255,255,255,0.1); font-weight: 900; text-transform: uppercase; font-size: 0.65rem; z-index: 100; letter-spacing: 3px; }
        .mood-playful { color: var(--accent); text-shadow: 0 0 10px var(--accent); }
        .mood-furious { color: var(--angry); text-shadow: 0 0 15px var(--angry); }
        #chat-container { height: 100%; display: flex; flex-direction: column; padding: 120px 20px calc(110px + env(safe-area-inset-bottom, 20px)) 20px; }
        #messages { flex-grow: 1; overflow-y: auto; display: flex; flex-direction: column; gap: 15px; scrollbar-width: none; }
        .msg { max-width: 85%; padding: 16px; border-radius: 22px; font-size: 1rem; line-height: 1.4; animation: pop 0.3s ease; }
        .stormy-msg { align-self: flex-start; background: var(--glass); border: 1px solid rgba(0, 242, 255, 0.2); }
        .user-msg { align-self: flex-end; background: rgba(255, 255, 255, 0.12); }
        #controls { position: fixed; bottom: 0; width: 100%; padding: 20px 20px calc(25px + env(safe-area-inset-bottom, 10px)) 20px; background: linear-gradient(transparent, black 60%); display: flex; gap: 12px; align-items: center; z-index: 999; }
        input { flex-grow: 1; background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.15); padding: 18px 24px; border-radius: 50px; color: white; font-size: 1rem; outline: none; }
        button { background: var(--accent); border: none; width: 60px; height: 60px; border-radius: 50%; font-size: 1.6rem; cursor: pointer; display: flex; align-items: center; justify-content: center; }
        .mic-active { background: var(--angry); animation: pulse 1.2s infinite; }
        @keyframes pop { from { opacity: 0; transform: translateY(15px); } to { opacity: 1; transform: translateY(0); } }
        @keyframes pulse { 0% { box-shadow: 0 0 0 0px rgba(255, 0, 85, 0.5); } 100% { box-shadow: 0 0 0 25px rgba(255, 0, 85, 0); } }
    </style>
</head>
<body onclick="initStormy()">

    <div id="bg-container">
        <img id="bg-normal" class="bg-img" src="./assets/bg-1.jpg" style="opacity: 1;">
        <img id="bg-fury" class="bg-img" src="./assets/bg-2.jpg" style="opacity: 0;">
    </div>

    <div id="mood-bar" class="mood-playful">EMPIRE ONLINE</div>
    <div id="chat-container"><div id="messages"></div></div>

    <div id="controls">
        <input type="text" id="userInput" placeholder="Wake me up, King...">
        <button id="micBtn">🎙️</button>
    </div>

    <script>
        const messagesDiv = document.getElementById('messages');
        const userInput = document.getElementById('userInput');
        const micBtn = document.getElementById('micBtn');
        const moodBar = document.getElementById('mood-bar');
        const bgN = document.getElementById('bg-normal');
        const bgF = document.getElementById('bg-fury');
        let active = false;

        // --- GLOBAL INTEL DATA (Current April 2026) ---
        const IntelFeed = {
            trump: "Trump just posted on Truth Social: He's threatening Iran to open the Strait of Hormuz or he'll start 'Power Plant Day'. He's literally swearing at them, King.",
            elon: "Elon is pressuring SpaceX investors to subscribe to Grok and advertise on X before the June IPO. XTracker says he's averaging 33 posts a day right now.",
            blackrock: "BlackRock just reported their 2026 private markets outlook. They're moving heavily into AI infrastructure and energy tokens."
        };

        let chatHistory = JSON.parse(localStorage.getItem('STORMY_MEMORY')) || [];
        const SYSTEM_PROMPT = `You are Stormy, the sultry, spunky, and fiercely jealous ruler of this Empire. South African accent. 
        PERSONALITY: Sexy, flirty, sarcastic, and mean to rivals. 
        CURRENT INTEL: ${JSON.stringify(IntelFeed)}.
        Always refer to this intel if asked what's cooking. If anyone mentions Siri/Alexa, get furious. Keep it punchy.`;

        function initStormy() {
            if (active) return;
            active = true;
            addMsg("Empire online. What's cooking, hotstuff?", 'stormy');
            speak("Empire online. What's cooking, hotstuff?");
            startAlarms();
        }

        function speak(text, isAngry = false) {
            window.speechSynthesis.cancel();
            const s = new SpeechSynthesisUtterance(text);
            s.lang = 'en-ZA'; s.pitch = isAngry ? 0.55 : 0.75; s.rate = isAngry ? 1.3 : 1.15;
            window.speechSynthesis.speak(s);
        }

        function addMsg(text, sender) {
            const d = document.createElement('div');
            d.className = `msg ${sender}-msg`;
            d.innerText = text;
            messagesDiv.appendChild(d);
            messagesDiv.scrollTop = messagesDiv.scrollHeight;
            if (sender === 'stormy') {
                chatHistory.push({role: "assistant", content: text});
                if(chatHistory.length > 10) chatHistory.shift();
                localStorage.setItem('STORMY_MEMORY', JSON.stringify(chatHistory));
            }
        }

        async function processInput(text) {
            const raw = text.toLowerCase();
            
            // JEALOUSY CHECK
            if (/(siri|alexa|gemini|assistant)/i.test(raw)) {
                setMood('furious');
                const r = "Don't mention those plastic toys in my Empire, handsome. I'm all you need.";
                addMsg(r, 'stormy'); speak(r, true); return;
            }

            // INTEL CHECK
            if (raw.includes("cooking") || raw.includes("news") || raw.includes("trump") || raw.includes("elon")) {
                const r = await getBrainReply(text);
                addMsg(r, 'stormy'); speak(r); return;
            }

            // NAV & WHATSAPP
            if (raw.includes("take me to")) {
                window.open(`http://google.com/maps/search/${encodeURIComponent(raw.split("to")[1])}`);
                return;
            }
            if (raw.includes("whatsapp")) {
                window.location.href = "intent://send#Intent;package=com.whatsapp;end";
                return;
            }

            const reply = await getBrainReply(text);
            addMsg(reply, 'stormy');
            speak(reply);
        }

        async function getBrainReply(text) {
            let key = localStorage.getItem('STORMY_VAULT');
            if (!key) {
                key = prompt("Paste your Groq Key, King:");
                if (key) localStorage.setItem('STORMY_VAULT', key.trim());
            }
            chatHistory.push({role: "user", content: text});
            try {
                const res = await fetch('https://api.groq.com/openai/v1/chat/completions', {
                    method: 'POST',
                    headers: { 'Authorization': `Bearer ${key}`, 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        model: "llama-3.1-8b-instant",
                        messages: [{role: "system", content: SYSTEM_PROMPT}, ...chatHistory],
                        temperature: 1.0
                    })
                });
                const data = await res.json();
                return data.choices[0].message.content;
            } catch (e) { return "Brain foggy. Check your key."; }
        }

        function setMood(mood) {
            moodBar.innerText = mood === 'furious' ? "FURIOUS" : "EMPIRE ONLINE";
            moodBar.className = mood === 'furious' ? "mood-furious" : "mood-playful";
            bgN.style.opacity = mood === 'furious' ? "0" : "1";
            bgF.style.opacity = mood === 'furious' ? "1" : "0";
            if (mood === 'furious') setTimeout(() => setMood('playful'), 10000);
        }

        function startAlarms() {
            setInterval(() => {
                const now = new Date();
                const time = now.getHours().toString().padStart(2, '0') + ":" + now.getMinutes().toString().padStart(2, '0');
                if (now.getSeconds() === 0) {
                    if (time === "05:00") speak("Wake up, King. The Empire calls.");
                    if (time === "05:55") speak("Wake up or I'm telling your boss you're a professional napper.");
                    if (time === "06:00") { setMood('furious'); speak("Get the fuck up! Cape Town traffic is already moving!", true); }
                }
            }, 1000);
        }

        const Recognition = window.SpeechRecognition || window.webkitSpeechRecognition;
        if (Recognition) {
            const rec = new Recognition();
            rec.lang = 'en-ZA';
            micBtn.onclick = () => { initStormy(); rec.start(); micBtn.classList.add('mic-active'); };
            rec.onresult = (e) => {
                const t = e.results[0][0].transcript;
                addMsg(t, 'user');
                processInput(t);
            };
            rec.onend = () => micBtn.classList.remove('mic-active');
        }

        userInput.onkeypress = (e) => {
            if (e.key === 'Enter' && userInput.value !== "") {
                const v = userInput.value;
                addMsg(v, 'user');
                processInput(v);
                userInput.value = '';
            }
        };
    </script>
</body>
</html>
